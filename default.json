{
    "extends": [
        "config:recommended",
        ":semanticCommitTypeAll(chore)",
        ":disablePeerDependencies",
        ":includeNodeModules",
        "helpers:pinGitHubActionDigestsToSemver",
        "github>kachick/renovate-config-dprint#1.3.0"
    ],
    "packageRules": [
        {
            "description": "Ignore Node.js",
            // We need to use "depName" instead of "packageName" if we want to 
            // ignore the "node" update in github actions. 
            // See https://github.com/renovatebot/renovate/blob/8510638513ed4b515688f249b9eca2a6c0336075/lib/modules/manager/github-actions/extract.ts#L253-L254
            "matchDepNames": [
                "@types/node",
                "node"
            ],
            "enabled": false
        },
        {
            "description": "Delay some packages since they tend to break something",
            "matchPackageNames": [
                "typescript",
                "eslint",
                "@eslint/*",
                "unocss",
                "@unocss/*"
            ],
            "minimumReleaseAge": "30 days",
            "dependencyDashboardApproval": true
        },
        {
            "groupName": "dependencies (non-major)",
            "matchUpdateTypes": [
                "patch",
                "minor",
                "digest"
            ],
            "minimumReleaseAge": "1 day",
            "dependencyDashboardApproval": true
        },
        {
            "matchUpdateTypes": [
                "major"
            ],
            "minimumReleaseAge": "30 days",
            "extends": [
                "schedule:monthly"
            ],
            "dependencyDashboardApproval": true
        }
    ],
    "lockFileMaintenance": {
        "enabled": true
    },
    "draftPR": true,
    "dependencyDashboardApproval": true,
    "postUpdateOptions": [
        "pnpmDedupe"
    ],
    "vulnerabilityAlerts": {
        "enabled": false
    },
    "branchNameStrict": true,
    "prConcurrentLimit": 2,
    "rangeStrategy": "bump"
}
