{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        ":semanticCommitTypeAll(chore)",
        ":widenPeerDependencies",
        ":includeNodeModules",
        "helpers:pinGitHubActionDigestsToSemver",
        "github>kachick/renovate-config-dprint#1a2f26400f460486aefe8ea1e9405b239917ebe9" // 1.3.0
    ],
    "packageRules": [
        {
            "description": "Ignore Node.js",
            // We need to use "depName" instead of "packageName" if we want to
            // ignore the "node" update in GitHub Actions.
            // See https://github.com/renovatebot/renovate/blob/8510638513ed4b515688f249b9eca2a6c0336075/lib/modules/manager/github-actions/extract.ts#L253-L254
            "matchDepNames": [
                "@types/node",
                "node"
            ],
            "enabled": false
        },
        {
            "description": "Group non-major updates (patch, minor, digest) into a single PR",
            "groupName": "dependencies",
            "groupSlug": "deps",
            "matchUpdateTypes": [
                "patch",
                "minor",
                "digest"
            ],
            "dependencyDashboardApproval": true,
            "minimumReleaseAge": "1 days"
        },
        // {
        //     // A minor update on a 0.x package (e.g. ^0.4.0 -> ^0.5.1) crosses
        //     // the caret compatibility range, so split it into its own PR while
        //     // keeping the same group name. The different "groupSlug" forces a
        //     // separate branch/PR even though "groupName" matches.
        //     "description": "Split potentially breaking 0.x minor updates into a separate PR",
        //     "groupName": "dependencies",
        //     "groupSlug": "deps",
        //     "matchUpdateTypes": [
        //         "minor"
        //     ],
        //     "matchCurrentVersion": "<1.0.0",
        //     "dependencyDashboardApproval": true,
        //     "minimumReleaseAge": "1 days"
        // },
        {
            "description": "Require a longer release age for major updates",
            "matchUpdateTypes": [
                "major"
            ],
            "dependencyDashboardApproval": true,
            "minimumReleaseAge": "7 days"
        },
        {
            "description": "Reduce noise from frequently-releasing packages",
            "dependencyDashboardApproval": true,
            "matchCurrentAge": "< 30 days",
            "minimumReleaseAge": "30 days"
        },
        {
            "description": "Update some trusted dependencies immediately",
            "matchPackageNames": [
                // Sorted alphabetically, ignoring the leading "@" character.
                "@aria-ui/*",
                "astro",
                "astro-minify-html-swc",
                "astro-theme-toggle",
                "astrobook",
                "@astrobook/*",
                "@astrojs/*",
                "diffable-html-snapshot",
                "histogram-diff",
                "@meowdown/*",
                "monorepo-typescript-references",
                "@ocavue/*",
                "@opencvjs/*",
                "prosekit",
                "@prosekit/*",
                "@prosemirror-adapter/*",
                "prosemirror-changeset",
                "prosemirror-commands",
                "prosemirror-drop-indicator",
                "prosemirror-dropcursor",
                "prosemirror-enter-rules",
                "prosemirror-flat-list",
                "prosemirror-gapcursor",
                "prosemirror-highlight",
                "prosemirror-history",
                "prosemirror-inputrules",
                "prosemirror-keymap",
                "prosemirror-math",
                "prosemirror-model",
                "prosemirror-safari-ime-span",
                "prosemirror-search",
                "prosemirror-splittable",
                "prosemirror-state",
                "prosemirror-tables",
                "prosemirror-transform",
                "prosemirror-view",
                "rehype-resolve-markdown-links",
                "satteri-resolve-markdown-links",
                "server-dom-shim",
                "shadcn-schema",
                "shiki-twoslash-renderer",
                "starlight-theme-nova",
                "vitest-browser-commands"
            ],
            "dependencyDashboardApproval": true,
            "minimumReleaseAge": "0 days"
        }
    ],
    "lockFileMaintenance": {
        "enabled": true,
        // Runs on the 1st of January each year
        "schedule": [
            "* * 1 1 *"
        ]
    },
    "draftPR": true,
    // Bump the heart emoji to signal a config update. Options: ❤️ 🩷 🧡 💛 💚 💙 🩵 💜
    "prHeader": "This PR was generated using [ocavue/config-renovate](https://github.com/ocavue/config-renovate) with 💛",
    "dependencyDashboardApproval": true,
    "postUpdateOptions": [
        "pnpmDedupe"
    ],
    "vulnerabilityAlerts": {
        "enabled": true,
        "groupName": "dependencies",
        "groupSlug": "deps",
        "dependencyDashboardApproval": true
    },
    "env": {
        "PNPM_MAX_WORKERS": "1"
    },
    "branchNameStrict": true,
    "prConcurrentLimit": 2,
    "rangeStrategy": "bump"
}
