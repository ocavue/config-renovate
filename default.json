{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        ":semanticCommitTypeAll(chore)",
        ":widenPeerDependencies",
        ":includeNodeModules",
        "helpers:pinGitHubActionDigestsToSemver",
        "github>kachick/renovate-config-dprint#1.3.0"
    ],
    "packageRules": [
        {
            "description": "Ignore Node.js",
            // We need to use "depName" instead of "packageName" if we want to
            // ignore the "node" update in github actions.
            // See https://github.com/renovatebot/renovate/blob/8510638513ed4b515688f249b9eca2a6c0336075/lib/modules/manager/github-actions/extract.ts#L253-L254
            "matchDepNames": [
                "@types/node",
                "node"
            ],
            "enabled": false
        },
        {
            "description": "Reduce noise",
            "matchPackageNames": [
                "eslint",
                "eslint-*",
                "@eslint-react/*",
                "@eslint/*",
                "@iconify-json/*",
                "jsdom",
                "katex",
                "knip",
                "next",
                "oxfmt",
                "playwright",
                "@playwright/*",
                "pnpm",
                "postcss",
                "preact",
                "prettier",
                "svelte",
                "svelte-*",
                "@sveltejs/*",
                "tailwindcss",
                "@tailwindcss/*",
                "turbo",
                "@types/*",
                "typescript",
                "@typescript/*",
                "unocss",
                "@unocss/*",
                "vite",
                "@vitejs/*",
                "vitest",
                "@vitest/*",
                "vue",
                "vue-*",
                "@vue/*",
                "wrangler"
            ],
            "matchCurrentAge": "< 14 days",
            "enabled": false
        },
        {
            "description": "Update some dependencies immediately",
            "matchPackageNames": [
                "astrobook",
                "@ocavue/*",
                "prosekit",
                "@prosekit/*",
                "prosemirror-*",
                "starlight-theme-nova"
            ],
            "minimumReleaseAge": "0 days"
        },
        {
            "groupName": "dependencies (non-major)",
            "matchUpdateTypes": [
                "patch",
                "minor",
                "digest"
            ],
            "minimumReleaseAge": "3 days"
        },
        {
            "matchUpdateTypes": [
                "major"
            ],
            "minimumReleaseAge": "7 days"
        }
    ],
    "lockFileMaintenance": {
        "enabled": true,
        "schedule": [
            "* * 1 */12 *"
        ]
    },
    "draftPR": true,
    "dependencyDashboardApproval": true,
    "postUpdateOptions": [
        "pnpmDedupe"
    ],
    "vulnerabilityAlerts": {
        "enabled": false
    },
    "env": {
        "PNPM_MAX_WORKERS": "1"
    },
    "branchNameStrict": true,
    "prConcurrentLimit": 2,
    "rangeStrategy": "bump"
}
